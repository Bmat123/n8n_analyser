# HTTP port the API listens on
PORT=3000

# Comma-separated approved database hostnames; suppresses DP-003 for these hosts
# Example: APPROVED_DB_HOSTS=db.internal,postgres.prod.svc.cluster.local
APPROVED_DB_HOSTS=

# Comma-separated approved outbound HTTP hostnames (opt-in egress allowlist for DP-006)
# When set, any HTTP Request node calling a host NOT in this list is flagged medium.
# Leave empty to disable DP-006 entirely.
# Example: APPROVED_EGRESS_HOSTS=api.stripe.com,api.sendgrid.com,hooks.slack.com
APPROVED_EGRESS_HOSTS=

# Comma-separated rule IDs to skip globally
# Example: DISABLED_RULES=HYG-002,DP-005
DISABLED_RULES=

# Minimum severity to include in violation output (low | medium | high | critical)
SEVERITY_THRESHOLD=low

# If true, redact matched secret strings in the evidence field before returning
REDACT_EVIDENCE=true

# Max body size for workflow JSON payloads
REQUEST_SIZE_LIMIT=5mb

# Gemini API key — enables the AI enhancement layer and fix suggestions (optional)
# Get one at https://aistudio.google.com/app/apikey
# Leave blank to run in static-analysis-only mode
GEMINI_API_KEY=

# Timeout in ms for fetching workflows from a live n8n instance (Mode B)
N8N_FETCH_TIMEOUT_MS=5000

# CORS origin for the dashboard (use * for open, or http://localhost:5173 for dev)
CORS_ORIGIN=http://localhost:5173

# ─── Graph Analysis Engine ────────────────────────────────────────────────────

# Enable graph-based rules alongside JSON rules (default: true)
ENABLE_GRAPH_ANALYSIS=true

# Enable LLM semantic escalation for ambiguous graph violations (default: false)
# Reuses GEMINI_API_KEY — no additional key required
ENABLE_LLM_ANALYSIS=false

# Timeout in ms for LLM graph escalation calls; violation falls back to advisory on timeout
LLM_TIMEOUT_MS=10000

# Max violations escalated to LLM per workflow (controls cost)
MAX_LLM_ESCALATIONS=5

# Standard deviations above mean to flag a node as high betweenness centrality
CENTRALITY_STDDEV_THRESHOLD=2.0

# Cyclomatic complexity thresholds
MAX_CYCLOMATIC_MEDIUM=10
MAX_CYCLOMATIC_HIGH=20

# Max paths computed by pathsBetween before truncation
GRAPH_MAX_PATH_COUNT=1000
