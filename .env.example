# HTTP port the API listens on
PORT=3000

# Comma-separated approved database hostnames; suppresses DP-003 for these hosts
# Example: APPROVED_DB_HOSTS=db.internal,postgres.prod.svc.cluster.local
APPROVED_DB_HOSTS=

# Comma-separated rule IDs to skip globally
# Example: DISABLED_RULES=HYG-002,DP-005
DISABLED_RULES=

# Minimum severity to include in violation output (low | medium | high | critical)
SEVERITY_THRESHOLD=low

# If true, redact matched secret strings in the evidence field before returning
REDACT_EVIDENCE=true

# Max body size for workflow JSON payloads
REQUEST_SIZE_LIMIT=5mb

# Gemini API key — enables the AI enhancement layer and fix suggestions (optional)
# Get one at https://aistudio.google.com/app/apikey
# Leave blank to run in static-analysis-only mode
GEMINI_API_KEY=

# Timeout in ms for fetching workflows from a live n8n instance (Mode B)
N8N_FETCH_TIMEOUT_MS=5000

# CORS origin for the dashboard (use * for open, or http://localhost:5173 for dev)
CORS_ORIGIN=http://localhost:5173
