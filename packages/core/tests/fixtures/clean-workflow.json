{
  "id": "wf-clean-001",
  "name": "Clean Payment Notifier",
  "active": true,
  "meta": {
    "description": "Fetches new orders hourly and notifies the ops Slack channel. Owned by the platform team."
  },
  "settings": {
    "errorWorkflow": "wf-error-handler"
  },
  "nodes": [
    {
      "id": "node-1",
      "name": "Scheduled Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [100, 200],
      "parameters": { "rule": { "interval": [{ "field": "hours", "hoursInterval": 1 }] } }
    },
    {
      "id": "node-2",
      "name": "Fetch Orders",
      "type": "n8n-nodes-base.httpRequest",
      "position": [300, 200],
      "parameters": {
        "url": "https://api.example.com/orders?page=1&limit=100",
        "requestMethod": "GET",
        "timeout": 10000,
        "authentication": "predefinedCredentialType"
      },
      "credentials": { "httpHeaderAuth": { "id": "cred-1", "name": "Orders API Key" } }
    },
    {
      "id": "node-3",
      "name": "Check Response",
      "type": "n8n-nodes-base.if",
      "position": [500, 200],
      "parameters": {
        "conditions": { "boolean": [{ "value1": "{{ $json.success }}", "value2": true }] }
      }
    },
    {
      "id": "node-5",
      "name": "Notify Slack",
      "type": "n8n-nodes-base.slack",
      "position": [700, 200],
      "parameters": {
        "channel": "#ops",
        "text": "New orders: {{ $json.count }}"
      }
    },
    {
      "id": "node-4",
      "name": "Error Handler",
      "type": "n8n-nodes-base.errorTrigger",
      "position": [100, 400],
      "parameters": {}
    }
  ],
  "connections": {
    "Scheduled Trigger": { "main": [[{ "node": "Fetch Orders", "type": "main", "index": 0 }]] },
    "Fetch Orders": { "main": [[{ "node": "Check Response", "type": "main", "index": 0 }]] },
    "Check Response": { "main": [[{ "node": "Notify Slack", "type": "main", "index": 0 }], []] }
  }
}
